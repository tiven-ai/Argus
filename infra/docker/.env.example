# Argus server env template.
# Copy to apps/server/.env and fill in real values for local dev. NEVER commit
# the populated file — root .gitignore excludes .env*.

# --- Core (M0–M4) ---
DATABASE_URL=postgres://argus:argus@localhost:5432/argus
PORT=4000
HOST=0.0.0.0
LOG_LEVEL=info
ARGUS_MODE=local                # 'local' = auto-default-user, 'multi-tenant' = real auth
JWT_SECRET=                     # ≥32 chars; required when ARGUS_MODE=multi-tenant
COOKIE_NAME=argus_session

# --- M5b OTLP gRPC ingest ---
GRPC_PORT=4317                  # 0 disables the gRPC server

# --- M7 RLS runtime role (auto-derived from DATABASE_URL if unset) ---
# APP_DATABASE_URL=postgres://argus_app:argus_app_dev_pwd@localhost:5432/argus
# ARGUS_APP_DB_PASSWORD=argus_app_dev_pwd

# --- M8 email flows (Resend) ---
RESEND_API_KEY=                 # e.g. re_xxx; throws at send-time if unset
EMAIL_FROM=Argus <noreply@argus.dev>
APP_BASE_URL=http://localhost:5173

# --- M9 cleanup crons (defaults shown) ---
# TOKEN_CLEANUP_INTERVAL_MS=3600000   # 0 disables
# AUDIT_CLEANUP_INTERVAL_MS=3600000   # 0 disables
# AUDIT_RETENTION_DAYS=90             # 0 disables
